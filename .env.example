# =============================================================================
# fandango_watcher — secrets template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Docker Compose reads `.env` automatically via `env_file:` in docker-compose.yml.
# After editing config + this file, run: fandango-watcher doctor
# (validates YAML + that notify.channels match available credentials).
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
TZ=America/Los_Angeles

# watch | once | dry-run
# - watch:    long-running poll loop (default in docker compose up)
# - once:     run a single crawl and exit (used by `fandango-watcher once`)
# - dry-run:  crawl + classify + would-notify, but send no SMS/email and
#             never click "Complete Reservation" in the purchaser
WATCHER_MODE=watch

# Path to the YAML config file inside the container.
WATCHER_CONFIG=/app/config.yaml

# Default TCP port for `watch` (/healthz + dashboard) when you omit --healthz-port / --port (default 8787).
# WATCHER_HEALTHZ_PORT=8787

# Set to `json` for one JSON object per log line on stderr (useful with log aggregators).
# LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Naming — four different vendors (do not mix these up):
#
#   OPENAI_API_KEY, OPENROUTER_API_KEY  → OpenAI / OpenRouter / other LLM hosts
#                                        (agent_fallback, etc.).
#   XAI_API_KEY, GROK_API_KEY           → xAI Grok only; api.x.ai (dashboard
#                                        release intel). Not the same as OpenAI.
#   X_API_KEY, X_BEARER_TOKEN           → X / Twitter Developer API
#                                        (developer.x.com social poll). This is
#                                        NOT xAI and NOT OpenAI — a separate product.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Twilio (SMS)
# Docs: https://www.twilio.com/docs/sms
# Create a project + buy a number, then copy SID / auth token from the console.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15555550123
NOTIFY_TO_E164=+15555550123

# -----------------------------------------------------------------------------
# SMTP (email)
# Gmail: use an App Password (not your login password).
# Other providers: SendGrid, Resend, Mailgun, ISP SMTP all work.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_TO_EMAIL=

# -----------------------------------------------------------------------------
# Agent fallback (Phase 6) — vision-LLM rescue when scripted purchaser
# breaks mid-checkout. Default provider is open-source `browser_use`.
#
# Two keys so you can keep providers separate in .env:
#
#   OPENROUTER_API_KEY  — used when `agent_fallback.base_url` contains
#                         openrouter.ai (see config.example.yaml).
#   OPENAI_API_KEY      — used for api.openai.com, Together, Fireworks,
#                         self-hosted vLLM, or any other OpenAI-compatible
#                         host that is NOT OpenRouter.
#
# If `base_url` is OpenRouter and OPENROUTER_API_KEY is empty, the code
# falls back to OPENAI_API_KEY (backward compatible). You can set both.
#
# Self-hosted vLLM with no auth: leave both empty (client sends "EMPTY").
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# xAI (Grok) — optional dashboard "release intel" (public release/ticketing news)
# OpenAI-compatible Chat Completions: https://docs.x.ai/docs/api-reference
# OpenAI / OpenRouter keys do NOT work on api.x.ai.
# Unrelated to X_API_KEY below (that is Twitter's API, not "X.AI").
# -----------------------------------------------------------------------------
XAI_API_KEY=
# Optional alias for the same bearer (some teams use this name):
GROK_API_KEY=
# Optional: overrides release_intel.model in config.yaml (e.g. grok-3-latest)
XAI_MODEL=

# -----------------------------------------------------------------------------
# X / Twitter Developer API (Phase 2 — social signals; NOT YET WIRED)
# Keys here are from developer.x.com — NOT xAI (Grok) and NOT OpenAI.
# Used to monitor official movie/studio accounts for early "tickets soon"
# hints alongside Fandango polling. Treated as advisory only — Fandango
# remains the source of truth for "can I buy?".
# Docs: https://docs.x.com/x-api
# Create app + keys: https://developer.x.com/en/portal/dashboard
# -----------------------------------------------------------------------------
X_API_KEY=
X_API_KEY_SECRET=
X_BEARER_TOKEN=
# Optional, only needed for user-context (posting / acting as account):
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare Workers deploy (optional) — `uv run pywrangler deploy` / scripts/deploy-worker.*
#
# In Cursor/agents and most CI, Wrangler cannot open a browser: set an API token.
# Create: https://developers.cloudflare.com/fundamentals/api/get-started/create-token/
# Suggested permissions: Workers Scripts (Edit), Workers Tail (Read), D1 (Edit if
# you create DBs from CLI), Account (Read). Browser Rendering uses the Worker.
#
# After auth, set Twilio/SMTP on the Worker with `npx wrangler secret put …`
# (same names as in .env above). `account_id` is in wrangler.toml.
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=

# Interactive-only alternative: run `npx wrangler login` locally (no token needed
# in .env for that machine). If you see OAuth 400 errors, run `npx wrangler logout`
# then log in again.
