# Per-project VPS settings — copy to vps/projects/<your-repo-name>.env
# No secrets here; only paths, ports, and compose wiring.

VPS_PROJECT_NAME=my-app
VPS_REMOTE_DIR=/root/my-app
VPS_REPO_URL=https://github.com/you/my-app.git

# Localhost-only bind on the VPS (pick an unused port — see vps/docs/COLOCATION.md)
VPS_HEALTHZ_PORT=7170
VPS_HEALTHZ_PATH=/healthz

# Space-separated compose files (relative to repo root on VPS)
VPS_COMPOSE_FILES="docker-compose.yml docker-compose.vps.yml"
VPS_COMPOSE_SERVICE=app

# Space-separated local:remote secret uploads (from laptop repo root)
VPS_SECRET_FILES=".env:.env.production"

# Optional — public HTTPS via Cloudflare Tunnel API (vps/scripts/cloudflare-publish.sh)
VPS_PUBLIC_HOSTNAME=my-app.example.com
VPS_TUNNEL_STRATEGY=reuse
VPS_TUNNEL_ID=7050a8bf-2e17-4b87-a74d-277ab6b9ffb3

# Optional — docker port holder pattern for preflight (regex fragment)
VPS_PORT_HOLDER_PATTERN="my-app|docker"
