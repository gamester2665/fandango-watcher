# Copy to vps/host.env (gitignored) for machine-local overrides.
# Shared across all projects on the same VPS.

VPS_HOST=74.48.91.123
VPS_SSH_USER=root

# Optional — password auth (prefer env at runtime, never commit real values)
# VPS_SSH_PASSWORD=
# ROSE_VPS_SSH_PASSWORD=

# Rose monorepo secrets file (SSH password line). Adjust path for your machine.
ROSE_SECRETS_VPS_MD=G:/_backup/Code/_mom/rose_astrology/secrets.vps.md

# Neighbor health checks (shared mail + Rose stack)
ROSE_PROD_URL=https://rose.geobregon.com/api/solar-snapshot?instant=2000-01-01T00:00:00.000Z
VPS_MAIL_UNITS="postfix dovecot nginx mariadb"
VPS_RESERVED_PORTS="7166 8989 8080 3306 25 587"
VPS_MIN_FREE_GIB=10
