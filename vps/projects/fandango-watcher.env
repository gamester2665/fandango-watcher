# fandango_watcher — VPS project config (no secrets)

VPS_PROJECT_NAME=fandango-watcher
VPS_REMOTE_DIR=/root/fandango-watcher
VPS_REPO_URL=https://github.com/gamester2665/fandango-watcher.git

VPS_HEALTHZ_PORT=8787
VPS_HEALTHZ_PATH=/healthz

VPS_COMPOSE_FILES="docker-compose.yml docker-compose.vps.yml"
VPS_COMPOSE_SERVICE=watcher

VPS_SECRET_FILES=".env:.env.production config.yaml:config.yaml"
VPS_PORT_HOLDER_PATTERN="fandango|docker.*watcher"

# Public HTTPS (Cloudflare Tunnel on rose-astrology connector)
VPS_PUBLIC_HOSTNAME=fandango.geobregon.com
VPS_TUNNEL_STRATEGY=reuse
VPS_TUNNEL_ID=7050a8bf-2e17-4b87-a74d-277ab6b9ffb3
